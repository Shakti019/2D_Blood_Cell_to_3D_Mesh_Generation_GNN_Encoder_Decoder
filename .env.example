# Optional environment variables — copy to .env and edit
# Leave blank to use defaults

# Server
HOST=0.0.0.0
PORT=8000

# Security — set to your domain in production, e.g. https://yourdomain.com
ALLOWED_ORIGINS=*

# Upload limit in megabytes
MAX_UPLOAD_MB=10

# Absolute or relative path to model weights (default: backend/bloodcell_hybrid_gnn.pth)
# WEIGHTS_PATH=/app/bloodcell_hybrid_gnn.pth
